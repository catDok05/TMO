			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Обычный" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
					<f size="10">
						<b>1. Построим графики функций </b>
					</f>
					<region region-id="434" left="145.5" top="2001.375" width="90" height="15" align-x="169.125" align-y="2010" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
						<math optimize="false" disable-calc="false">
							<ml:apply xmlns:ml="http://schemas.mathsoft.com/math30">
								<ml:equal/>
								<ml:apply>
									<ml:id xml:space="preserve">f</ml:id>
									<ml:id xml:space="preserve">τ</ml:id>
								</ml:apply>
								<ml:apply>
									<ml:id xml:space="preserve">ln</ml:id>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">υ</ml:id>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve" subscript="ж ">t</ml:id>
											<ml:id xml:space="preserve">t</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</math>
						<rendering item-idref="12"/>
					</region>
					<f family="Times New Roman" charset="0" size="10">
						<b>
							<inlineAttr font-style="normal" underline="false" line-through="false">. Для этого найдём все нужные значения:</inlineAttr>
						</b>
					</f>
				</p>
			</text>
		</region>
